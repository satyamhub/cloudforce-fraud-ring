USE GLOBAL

DROP GRAPH Demo

CREATE VERTEX Person (
  PRIMARY_ID id STRING,
  name STRING
)

CREATE UNDIRECTED EDGE Knows (
  FROM Person,
  TO Person,
  strength INT
)

CREATE GRAPH Demo(Person, Knows)

USE GRAPH Demo

CREATE LOADING JOB load_people FOR GRAPH Demo {
  DEFINE FILENAME f1;
  LOAD f1 TO VERTEX Person VALUES ($0, $1) USING SEPARATOR=",";
  LOAD f1 TO EDGE Knows VALUES ($0, $2, $3) USING SEPARATOR=",";
}
